generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Per-shop configuration for the Cart Rescue journey
model ShopSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  senderName       String   @default("Your Store")
  senderEmail      String   @default("")
  replyTo          String   @default("")
  brandColor       String   @default("#000000")
  logoUrl          String   @default("")
  quietHoursStart  Int      @default(22) // hour 0-23 in store timezone
  quietHoursEnd    Int      @default(8)
  storeTimezone    String   @default("UTC")
  // Domain verification
  verifiedDomain   String   @default("")
  domainVerified   Boolean  @default(false)
  // Onboarding
  onboardingStep   Int      @default(0) // 0=not started, 1=domain, 2=template, 3=done
  isActive         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Journey configuration — one per shop
model JourneySettings {
  id              String   @id @default(cuid())
  shop            String   @unique
  templateStyle   String   @default("classic") // classic | bold | minimal
  // Email 1
  email1Enabled   Boolean  @default(true)
  email1DelayHours Float   @default(1)
  email1Subject   String   @default("You left something behind")
  email1Body      String   @default("")
  // Email 2
  email2Enabled   Boolean  @default(true)
  email2DelayHours Float   @default(24)
  email2Subject   String   @default("Still thinking it over?")
  email2Body      String   @default("")
  // Email 3
  email3Enabled   Boolean  @default(true)
  email3DelayHours Float   @default(72)
  email3Subject   String   @default("Last chance — 10% off")
  email3Body      String   @default("")
  email3DiscountPct Int    @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Tracks an abandoned checkout session
model AbandonedCart {
  id              String   @id @default(cuid())
  shop            String
  checkoutToken   String
  checkoutId      String
  cartToken       String   @default("")
  customerEmail   String
  customerName    String   @default("")
  totalPrice      Float
  currency        String   @default("USD")
  lineItemsJson   String   // JSON serialised line items
  recoveryUrl     String
  abandonedAt     DateTime @default(now())
  recoveredAt     DateTime?
  recoveredRevenue Float?
  // Journey state
  email1SentAt    DateTime?
  email2SentAt    DateTime?
  email3SentAt    DateTime?
  discountCode    String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  emails          CartRescueEmail[]
  jobs            EmailJob[]

  @@unique([shop, checkoutToken])
  @@index([shop, customerEmail])
  @@index([shop, recoveredAt])
}

// Individual email send record for analytics
model CartRescueEmail {
  id              String   @id @default(cuid())
  shop            String
  abandonedCartId String
  emailNumber     Int      // 1, 2, or 3
  to              String
  subject         String
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  bounced         Boolean  @default(false)
  unsubscribed    Boolean  @default(false)
  // Resend message id for event webhooks
  resendMessageId String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  abandonedCart   AbandonedCart @relation(fields: [abandonedCartId], references: [id], onDelete: Cascade)

  @@index([shop, sentAt])
  @@index([resendMessageId])
}

// DB-backed job queue for delayed email sends
model EmailJob {
  id              String   @id @default(cuid())
  shop            String
  abandonedCartId String
  emailNumber     Int      // 1, 2, or 3
  scheduledFor    DateTime
  status          String   @default("pending") // pending | processing | done | failed | cancelled
  attempts        Int      @default(0)
  lastError       String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  abandonedCart   AbandonedCart @relation(fields: [abandonedCartId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, abandonedCartId])
}

// Email suppression / unsubscribe list
model EmailSuppression {
  id        String   @id @default(cuid())
  shop      String
  email     String
  reason    String   @default("unsubscribe") // unsubscribe | bounce | complaint
  createdAt DateTime @default(now())

  @@unique([shop, email])
  @@index([shop, email])
}

// Popup signup capture
model PopupSignup {
  id            String    @id @default(cuid())
  shop          String
  email         String
  source        String    @default("exit_intent_popup")
  discountCode  String    @default("")
  confirmToken  String    @default("")
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([shop, email])
}

// Per-shop popup widget configuration
model PopupSettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  headline    String   @default("Wait — don't go yet!")
  bodyText    String   @default("Enter your email and get 10% off your first order.")
  buttonText  String   @default("Get my discount")
  brandColor  String   @default("#000000")
  logoUrl     String   @default("")
  discountPct Int      @default(10)
  delayMs     Int      @default(3000)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Flexible journey engine — a playbook (welcome, win-back, post-purchase, etc.)
model Journey {
  id          String   @id @default(cuid())
  shop        String
  name        String
  trigger     String   // cart_abandoned | customer_created | order_placed | win_back
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       JourneyStep[]
  enrollments JourneyEnrollment[]

  @@index([shop, trigger])
}

// One email step within a journey
model JourneyStep {
  id            String   @id @default(cuid())
  journeyId     String
  stepNumber    Int
  delayHours    Float    @default(1)
  subject       String   @default("")
  templateStyle String   @default("classic")
  discountPct   Int      @default(0)
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journey       Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  jobs          JourneyJob[]

  @@index([journeyId, stepNumber])
}

// One contact enrolled in a journey
model JourneyEnrollment {
  id            String    @id @default(cuid())
  shop          String
  journeyId     String
  contactEmail  String
  contactName   String    @default("")
  payload       String    @default("{}")
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?
  exitReason    String    @default("")

  journey       Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  jobs          JourneyJob[]

  @@index([shop, contactEmail])
  @@index([journeyId])
}

// Scheduled send per step per enrollment
model JourneyJob {
  id              String    @id @default(cuid())
  shop            String
  enrollmentId    String
  stepId          String
  scheduledFor    DateTime
  status          String    @default("pending")
  attempts        Int       @default(0)
  lastError       String    @default("")
  resendMessageId String    @default("")
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  enrollment      JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step            JourneyStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, enrollmentId])
}
