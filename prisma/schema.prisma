generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Per-shop configuration for the Cart Rescue journey
model ShopSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  senderName       String   @default("Your Store")
  senderEmail      String   @default("")
  replyTo          String   @default("")
  emailProvider    String   @default("resend") // resend | ses
  brandColor       String   @default("#000000")
  logoUrl          String   @default("")
  quietHoursStart  Int      @default(22) // hour 0-23 in store timezone
  quietHoursEnd    Int      @default(8)
  storeTimezone    String   @default("UTC")
  // Domain verification
  verifiedDomain   String   @default("")
  domainVerified   Boolean  @default(false)
  // Onboarding
  onboardingStep   Int      @default(0) // 0=not started, 1=sender saved, 2=done
  isActive         Boolean  @default(false)
  pushEnabled      Boolean  @default(false)
  // WhatsApp channel (Meta Cloud API). Off by default; flipped on per shop
  // once the merchant connects a WABA via Embedded Signup and approval lands.
  whatsappEnabled  Boolean  @default(false)
  whatsappProvider String   @default("meta") // meta | (future BSP)
  // When true (default, Meta-compliant), WhatsApp only sends to confirmed
  // opt-ins. When a merchant explicitly disables this, the worker will send to
  // any enrolled contact that has a phone number (opt-outs/suppression are
  // ALWAYS honored regardless of this flag).
  whatsappRequireOptIn Boolean @default(true)
  // Contacts feature — one-time backfill flag + Shopify customer sync state
  contactsBackfilledAt              DateTime?
  lastShopifyCustomerSyncAt         DateTime?
  shopifyCustomerSyncCursor         String?
  shopifyCustomerSyncStatus         String   @default("idle") // idle | running | failed
  shopifyCustomerSyncTotal          Int?
  shopifyCustomerSyncDone           Int?
  shopifyCustomerSyncIncludeNonOptIn Boolean @default(false)
  shopifyCustomerSyncLastError      String   @default("")
  // Segments feature — daily snapshot worker. No-op unless ≥24h elapsed.
  lastSegmentSnapshotAt             DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Unified contact record per shop+email. Source of truth for browsing audience.
// Other tables (AbandonedCart, PopupSignup, PushSubscription, EmailSuppression,
// JourneyEnrollment) still key on `email` string — no FKs added.
model Contact {
  id                  String    @id @default(cuid())
  shop                String
  email               String    // always lowercased + trimmed on write
  name                String    @default("")
  firstSeenAt         DateTime  @default(now())
  lastSeenAt          DateTime  @default(now())
  source              String    @default("manual") // popup | cart_abandoned | shopify_customer | csv_import | push_only | manual
  subscriptionStatus  String    @default("never_opted_in") // subscribed | unsubscribed | bounced | complained | never_opted_in
  marketingConsentAt  DateTime?
  shopifyCustomerId   String?
  // WhatsApp facets — phone is E.164, whatsappStatus is a separate consent axis
  // from email subscriptionStatus (a contact can be email-subscribed but not
  // WhatsApp-opted-in, or vice versa). WhatsappSubscription holds the detail.
  phone               String?
  whatsappStatus      String    @default("never_opted_in") // subscribed | unsubscribed | invalid | never_opted_in
  whatsappOptInAt     DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tags                ContactTag[]

  @@unique([shop, email])
  @@index([shop, lastSeenAt])
  @@index([shop, source])
  @@index([shop, subscriptionStatus])
  @@index([shop, whatsappStatus])
}

// Merchant-defined tag — per shop. `nameKey` is the lowercased uniqueness key;
// `name` keeps original display case.
model Tag {
  id        String   @id @default(cuid())
  shop      String
  name      String
  nameKey   String
  color     String   @default("forest") // forest | blue | amber | purple | tan | red
  createdAt DateTime @default(now())

  contacts  ContactTag[]

  @@unique([shop, nameKey])
}

// Join table — tag membership on a contact.
model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

// Saved audience group — dynamic (rule tree) or static (explicit member list).
// Used for browsing, and (in a follow-up phase) for flow triggers.
model Segment {
  id             String   @id @default(cuid())
  shop           String
  name           String
  description    String   @default("")
  kind           String   // "dynamic" | "static"
  filterTree     Json?    // root group for dynamic; null for static
  contactCount   Int      @default(0)
  lastComputedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  memberships    SegmentMembership[]

  @@index([shop, deletedAt])
  @@index([shop, updatedAt])
}

// Per-contact entry log for a segment. Powers the segment detail Activity
// tab (Recently entered / left) AND the enrollment worker's diff between
// runs. Both static and dynamic segments write here:
//   - Static: from addStaticMember/removeStaticMember (synchronously).
//   - Dynamic: from the segment enrollment worker on each tick.
// segmentKey matches Segment.id OR a sys_* system segment key.
model SegmentEntryLog {
  id         String    @id @default(cuid())
  shop       String
  segmentKey String
  contactId  String
  enteredAt  DateTime  @default(now())
  leftAt     DateTime?

  @@index([shop, segmentKey, enteredAt])
  @@index([shop, segmentKey, leftAt])
  @@index([contactId])
}

// Daily size snapshot for the Activity tab sparkline. The snapshot worker
// writes one row per segment per UTC day and prunes anything older than 30
// days for that segmentKey.
model SegmentSnapshot {
  id         String   @id @default(cuid())
  shop       String
  segmentKey String
  takenAt    DateTime @default(now())
  count      Int

  @@index([shop, segmentKey, takenAt])
}

// Explicit membership row for static segments. (Dynamic segments don't write
// to this table — they evaluate on read.)
model SegmentMembership {
  id        String   @id @default(cuid())
  segmentId String
  contactId String   // points at Contact.id; joined by app logic
  addedAt   DateTime @default(now())

  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, contactId])
  @@index([segmentId])
  @@index([contactId])
}

// Tracks an abandoned checkout session
model AbandonedCart {
  id              String   @id @default(cuid())
  shop            String
  checkoutToken   String
  checkoutId      String
  cartToken       String   @default("")
  customerEmail   String
  customerName    String   @default("")
  totalPrice      Float
  currency        String   @default("USD")
  lineItemsJson   String   // JSON serialised line items
  recoveryUrl     String
  abandonedAt     DateTime @default(now())
  recoveredAt     DateTime?
  recoveredRevenue Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, checkoutToken])
  @@index([shop, customerEmail])
  @@index([shop, recoveredAt])
}

// Email suppression / unsubscribe list
model EmailSuppression {
  id        String   @id @default(cuid())
  shop      String
  email     String
  reason    String   @default("unsubscribe") // unsubscribe | bounce | complaint
  createdAt DateTime @default(now())

  @@unique([shop, email])
  @@index([shop, email])
}

// Popup signup capture
model PopupSignup {
  id            String    @id @default(cuid())
  shop          String
  email         String
  source        String    @default("exit_intent_popup")
  discountCode  String    @default("")
  confirmToken  String    @default("")
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([shop, email])
}

// Per-shop popup widget configuration
model PopupSettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  enabled     Boolean  @default(true)
  template    String   @default("editorial")
  config      Json?
  // Legacy columns — kept during storefront rollout, dropped in follow-up migration.
  headline    String   @default("Wait — don't go yet!")
  bodyText    String   @default("Enter your email and get 10% off your first order.")
  buttonText  String   @default("Get my discount")
  brandColor  String   @default("#000000")
  logoUrl     String   @default("")
  discountPct Int      @default(10)
  delayMs     Int      @default(3000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Flexible journey engine — a playbook (welcome, win-back, post-purchase, etc.)
model Journey {
  id               String    @id @default(cuid())
  shop             String
  name             String
  trigger          String    // cart_abandoned | customer_created | order_placed | win_back | segment_entered
  isActive         Boolean   @default(false)
  status           String    @default("draft")        // draft | published | paused
  publishedAt      DateTime?
  publishedVersion Int       @default(0)
  draftVersion     Int       @default(0)
  entryFrequency   String    @default("no_reentry")   // immediate | delayed_<hours> | no_reentry
  exitCriteria     String    @default("[]")           // JSON array of event keys
  source           String    @default("flows")        // flows | automations | cart_rescue_legacy
  archivedAt       DateTime?
  // Segments trigger metadata. triggerSegmentKey holds Segment.id (cuid) or
  // a sys_* key for built-in system segments. lastEnrollmentAt/Hash drive
  // the staggered enrollment worker — never bypass via hand edits.
  triggerSegmentKey  String?
  lastEnrollmentAt   DateTime?
  lastEnrollmentHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  steps       JourneyStep[]
  enrollments JourneyEnrollment[]

  @@index([shop, trigger])
  @@index([shop, status])
  @@index([trigger, status, lastEnrollmentAt])
}

// One step within a journey (email send, time delay, push, or exit)
model JourneyStep {
  id            String   @id @default(cuid())
  journeyId     String
  stepNumber    Int
  nodeType      String   @default("email") // email | delay | exit | push | whatsapp
  positionY     Int      @default(0)
  delayHours    Float    @default(1)
  subject       String   @default("")
  previewText   String   @default("")
  emailName     String   @default("")
  templateStyle String   @default("classic")
  discountPct   Int      @default(0)
  isEnabled     Boolean  @default(true)
  // Set when a draft edit replaced this step but in-flight jobs still
  // reference it. Archived steps are excluded from the builder canvas and
  // step counts, but kept so their JourneyJobs are not cascade-deleted.
  isArchived    Boolean  @default(false)
  emailBlocks   String   @default("[]")   // JSON array of block objects
  emailBrand    String   @default("{}")   // JSON brand kit object
  // Email authoring mode. "blocks" (default) renders emailBlocks/emailBrand via
  // the visual renderer; "html" sends the merchant's pasted emailHtml verbatim
  // (merge tags + unsubscribe still applied at send time).
  emailMode     String   @default("blocks") // blocks | html
  emailHtml     String   @default("")        // raw pasted HTML (used when emailMode = "html")
  // Push notification fields
  pushTitle     String   @default("")
  pushBody      String   @default("")
  pushIconUrl   String   @default("")
  pushClickUrl  String   @default("")
  // WhatsApp fields — references a Meta-approved HSM template by name+language.
  // waVariables maps positional template params ({{1}},{{2}}...) to a merge-tag
  // or enrollment-payload key resolved at send time.
  waTemplateName String  @default("")
  waLanguage     String  @default("")
  waVariables    Json?
  waMediaUrl     String  @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journey       Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  jobs          JourneyJob[]
  pushJobs      PushJob[]
  whatsappJobs  WhatsappJob[]

  @@index([journeyId, stepNumber])
}

// Pre-configured flow templates (seed data)
model JourneyTemplate {
  id          String   @id @default(cuid())
  key         String   @unique // welcome_series | abandoned_cart | post_purchase | winback
  name        String
  description String   @default("")
  trigger     String
  category    String   @default("") // welcome | cart | post_purchase | winback | special_occasion
  bestFor     String   @default("[]") // JSON array of bullet strings
  definition  String   @default("{}") // JSON: { steps, entryFrequency, exitCriteria }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// One contact enrolled in a journey
model JourneyEnrollment {
  id            String    @id @default(cuid())
  shop          String
  journeyId     String
  contactEmail  String
  contactName   String    @default("")
  payload       String    @default("{}")
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?
  exitReason    String    @default("")

  journey       Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  jobs          JourneyJob[]
  pushJobs      PushJob[]
  whatsappJobs  WhatsappJob[]

  @@index([shop, contactEmail])
  @@index([journeyId])
}

// Scheduled send per step per enrollment
model JourneyJob {
  id              String    @id @default(cuid())
  shop            String
  enrollmentId    String
  stepId          String
  scheduledFor    DateTime
  status          String    @default("pending")
  attempts        Int       @default(0)
  lastError       String    @default("")
  resendMessageId String    @default("")
  providerMessageId String  @default("")
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  enrollment      JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step            JourneyStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, enrollmentId])
  @@index([resendMessageId])
  @@index([providerMessageId])
}

// Browser push subscriptions — one row per browser per shop
model PushSubscription {
  id             String    @id @default(cuid())
  shop           String
  endpoint       String
  p256dh         String
  auth           String
  contactEmail   String?
  anonId         String?
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@unique([shop, endpoint])
  @@index([shop, contactEmail])
  @@index([shop, anonId])
}

// Scheduled push notification per push step per enrollment
model PushJob {
  id           String    @id @default(cuid())
  shop         String
  enrollmentId String
  stepId       String
  scheduledFor DateTime
  status       String    @default("pending") // pending | processing | done | failed | cancelled
  attempts     Int       @default(0)
  lastError    String    @default("")
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollment   JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step         JourneyStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, enrollmentId])
}

// Per-shop WhatsApp Business Account, connected via Meta Embedded Signup.
// accessTokenEnc is AES-256-GCM ciphertext (see app/lib/crypto/secrets.server.js)
// — the long-lived system-user token is never stored in plaintext.
model WhatsappAccount {
  id                 String    @id @default(cuid())
  shop               String    @unique
  wabaId             String    @default("")
  phoneNumberId      String    @default("")
  displayPhoneNumber String    @default("")
  businessId         String    @default("")
  accessTokenEnc     String    @default("")
  status             String    @default("pending") // pending | connected | disconnected
  connectedAt        DateTime?
  // Cloud API registration (POST /{phoneNumberId}/register). A number must be
  // registered before it can send ANY message (template or free-text); without
  // it Meta returns error #133010 "Account not registered".
  registeredAt       DateTime?
  lastError          String    @default("")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// Meta-approved message templates (HSM) synced from a shop's WABA.
model WhatsappTemplate {
  id            String   @id @default(cuid())
  shop          String
  name          String
  language      String
  category      String   @default("MARKETING") // MARKETING | UTILITY | AUTHENTICATION
  metaTemplateId String  @default("")
  status        String   @default("PENDING")   // PENDING | APPROVED | REJECTED | DISABLED
  bodyText      String   @default("")
  components    Json?    // raw Meta component spec, used to map variables
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, name, language])
  @@index([shop, status])
}

// WhatsApp opt-in record — one row per phone per shop. Mirrors PushSubscription's
// contactEmail linkage back into the Contact graph.
model WhatsappSubscription {
  id            String    @id @default(cuid())
  shop          String
  phoneNumber   String    // E.164
  contactEmail  String?
  status        String    @default("subscribed") // subscribed | unsubscribed | invalid
  optInMethod   String?   // popup | checkout | click_to_wa | imported | api
  confirmedAt   DateTime? // double opt-in confirmation
  lastInboundAt DateTime? // last customer-initiated message — drives 24h session window
  optInAt       DateTime  @default(now())
  optOutAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shop, phoneNumber])
  @@index([shop, contactEmail])
}

// Scheduled WhatsApp send per whatsapp step per enrollment. Mirrors PushJob.
model WhatsappJob {
  id                String    @id @default(cuid())
  shop              String
  enrollmentId      String
  stepId            String
  scheduledFor      DateTime
  status            String    @default("pending") // pending | processing | done | failed | cancelled
  attempts          Int       @default(0)
  lastError         String    @default("")
  templateName      String    @default("")
  providerMessageId String    @default("") // Meta wamid — matched by the status webhook
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  enrollment        JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step              JourneyStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, enrollmentId])
  @@index([providerMessageId])
}

// Suppression list for WhatsApp — parallel to EmailSuppression.
model WhatsappSuppression {
  id          String   @id @default(cuid())
  shop        String
  phoneNumber String
  reason      String   // opt_out | blocked | invalid
  createdAt   DateTime @default(now())

  @@unique([shop, phoneNumber])
}
