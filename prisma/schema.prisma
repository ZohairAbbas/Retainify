generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Per-shop configuration for the Cart Rescue journey
model ShopSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  senderName       String   @default("Your Store")
  senderEmail      String   @default("")
  replyTo          String   @default("")
  brandColor       String   @default("#000000")
  logoUrl          String   @default("")
  quietHoursStart  Int      @default(22) // hour 0-23 in store timezone
  quietHoursEnd    Int      @default(8)
  storeTimezone    String   @default("UTC")
  // Domain verification
  verifiedDomain   String   @default("")
  domainVerified   Boolean  @default(false)
  // Onboarding
  onboardingStep   Int      @default(0) // 0=not started, 1=sender saved, 2=done
  isActive         Boolean  @default(false)
  pushEnabled      Boolean  @default(false)
  // Contacts feature — one-time backfill flag + Shopify customer sync state
  contactsBackfilledAt              DateTime?
  lastShopifyCustomerSyncAt         DateTime?
  shopifyCustomerSyncCursor         String?
  shopifyCustomerSyncStatus         String   @default("idle") // idle | running | failed
  shopifyCustomerSyncTotal          Int?
  shopifyCustomerSyncDone           Int?
  shopifyCustomerSyncIncludeNonOptIn Boolean @default(false)
  shopifyCustomerSyncLastError      String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Unified contact record per shop+email. Source of truth for browsing audience.
// Other tables (AbandonedCart, PopupSignup, PushSubscription, EmailSuppression,
// JourneyEnrollment) still key on `email` string — no FKs added.
model Contact {
  id                  String    @id @default(cuid())
  shop                String
  email               String    // always lowercased + trimmed on write
  name                String    @default("")
  firstSeenAt         DateTime  @default(now())
  lastSeenAt          DateTime  @default(now())
  source              String    @default("manual") // popup | cart_abandoned | shopify_customer | csv_import | push_only | manual
  subscriptionStatus  String    @default("never_opted_in") // subscribed | unsubscribed | bounced | complained | never_opted_in
  marketingConsentAt  DateTime?
  shopifyCustomerId   String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tags                ContactTag[]

  @@unique([shop, email])
  @@index([shop, lastSeenAt])
  @@index([shop, source])
  @@index([shop, subscriptionStatus])
}

// Merchant-defined tag — per shop. `nameKey` is the lowercased uniqueness key;
// `name` keeps original display case.
model Tag {
  id        String   @id @default(cuid())
  shop      String
  name      String
  nameKey   String
  color     String   @default("forest") // forest | blue | amber | purple | tan | red
  createdAt DateTime @default(now())

  contacts  ContactTag[]

  @@unique([shop, nameKey])
}

// Join table — tag membership on a contact.
model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

// Tracks an abandoned checkout session
model AbandonedCart {
  id              String   @id @default(cuid())
  shop            String
  checkoutToken   String
  checkoutId      String
  cartToken       String   @default("")
  customerEmail   String
  customerName    String   @default("")
  totalPrice      Float
  currency        String   @default("USD")
  lineItemsJson   String   // JSON serialised line items
  recoveryUrl     String
  abandonedAt     DateTime @default(now())
  recoveredAt     DateTime?
  recoveredRevenue Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, checkoutToken])
  @@index([shop, customerEmail])
  @@index([shop, recoveredAt])
}

// Email suppression / unsubscribe list
model EmailSuppression {
  id        String   @id @default(cuid())
  shop      String
  email     String
  reason    String   @default("unsubscribe") // unsubscribe | bounce | complaint
  createdAt DateTime @default(now())

  @@unique([shop, email])
  @@index([shop, email])
}

// Popup signup capture
model PopupSignup {
  id            String    @id @default(cuid())
  shop          String
  email         String
  source        String    @default("exit_intent_popup")
  discountCode  String    @default("")
  confirmToken  String    @default("")
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([shop, email])
}

// Per-shop popup widget configuration
model PopupSettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  enabled     Boolean  @default(true)
  template    String   @default("editorial")
  config      Json?
  // Legacy columns — kept during storefront rollout, dropped in follow-up migration.
  headline    String   @default("Wait — don't go yet!")
  bodyText    String   @default("Enter your email and get 10% off your first order.")
  buttonText  String   @default("Get my discount")
  brandColor  String   @default("#000000")
  logoUrl     String   @default("")
  discountPct Int      @default(10)
  delayMs     Int      @default(3000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Flexible journey engine — a playbook (welcome, win-back, post-purchase, etc.)
model Journey {
  id               String    @id @default(cuid())
  shop             String
  name             String
  trigger          String    // cart_abandoned | customer_created | order_placed | win_back
  isActive         Boolean   @default(false)
  status           String    @default("draft")        // draft | published | paused
  publishedAt      DateTime?
  publishedVersion Int       @default(0)
  draftVersion     Int       @default(0)
  entryFrequency   String    @default("no_reentry")   // immediate | delayed_<hours> | no_reentry
  exitCriteria     String    @default("[]")           // JSON array of event keys
  source           String    @default("flows")        // flows | automations | cart_rescue_legacy
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  steps       JourneyStep[]
  enrollments JourneyEnrollment[]

  @@index([shop, trigger])
  @@index([shop, status])
}

// One step within a journey (email send, time delay, push, or exit)
model JourneyStep {
  id            String   @id @default(cuid())
  journeyId     String
  stepNumber    Int
  nodeType      String   @default("email") // email | delay | exit | push
  positionY     Int      @default(0)
  delayHours    Float    @default(1)
  subject       String   @default("")
  previewText   String   @default("")
  emailName     String   @default("")
  templateStyle String   @default("classic")
  discountPct   Int      @default(0)
  isEnabled     Boolean  @default(true)
  // Set when a draft edit replaced this step but in-flight jobs still
  // reference it. Archived steps are excluded from the builder canvas and
  // step counts, but kept so their JourneyJobs are not cascade-deleted.
  isArchived    Boolean  @default(false)
  emailBlocks   String   @default("[]")   // JSON array of block objects
  emailBrand    String   @default("{}")   // JSON brand kit object
  // Push notification fields
  pushTitle     String   @default("")
  pushBody      String   @default("")
  pushIconUrl   String   @default("")
  pushClickUrl  String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journey       Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  jobs          JourneyJob[]
  pushJobs      PushJob[]

  @@index([journeyId, stepNumber])
}

// Pre-configured flow templates (seed data)
model JourneyTemplate {
  id          String   @id @default(cuid())
  key         String   @unique // welcome_series | abandoned_cart | post_purchase | winback
  name        String
  description String   @default("")
  trigger     String
  category    String   @default("") // welcome | cart | post_purchase | winback | special_occasion
  bestFor     String   @default("[]") // JSON array of bullet strings
  definition  String   @default("{}") // JSON: { steps, entryFrequency, exitCriteria }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// One contact enrolled in a journey
model JourneyEnrollment {
  id            String    @id @default(cuid())
  shop          String
  journeyId     String
  contactEmail  String
  contactName   String    @default("")
  payload       String    @default("{}")
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?
  exitReason    String    @default("")

  journey       Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  jobs          JourneyJob[]
  pushJobs      PushJob[]

  @@index([shop, contactEmail])
  @@index([journeyId])
}

// Scheduled send per step per enrollment
model JourneyJob {
  id              String    @id @default(cuid())
  shop            String
  enrollmentId    String
  stepId          String
  scheduledFor    DateTime
  status          String    @default("pending")
  attempts        Int       @default(0)
  lastError       String    @default("")
  resendMessageId String    @default("")
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  enrollment      JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step            JourneyStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, enrollmentId])
  @@index([resendMessageId])
}

// Browser push subscriptions — one row per browser per shop
model PushSubscription {
  id             String    @id @default(cuid())
  shop           String
  endpoint       String
  p256dh         String
  auth           String
  contactEmail   String?
  anonId         String?
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@unique([shop, endpoint])
  @@index([shop, contactEmail])
  @@index([shop, anonId])
}

// Scheduled push notification per push step per enrollment
model PushJob {
  id           String    @id @default(cuid())
  shop         String
  enrollmentId String
  stepId       String
  scheduledFor DateTime
  status       String    @default("pending") // pending | processing | done | failed | cancelled
  attempts     Int       @default(0)
  lastError    String    @default("")
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollment   JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step         JourneyStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([shop, enrollmentId])
}
